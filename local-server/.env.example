# Weaper Local Sync Server Configuration

# Port for the HTTP server
PORT=3000

# Directory where uploaded audio files will be stored
# This should be the REAPER media directory or a linked folder
UPLOAD_DIR=/Users/user/Documents/REAPER Media/Weaper

# Maximum file size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=mp3,wav,aif,aiff,flac

# CORS - allowed origins (Android app)
ALLOWED_ORIGINS=*
